---
/**
 * Plugins Hub — role-based Claude Code plugins.
 *
 * Density: LOW (hero) → HIGH (directory) → LOW (rupture) →
 *          MED (signup) → LOW (CTA void)
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import ToolCard from '../../components/ToolCard.astro';
import EmailSignup from '../../components/EmailSignup.astro';

const allTools = await getCollection('tools');
const plugins = allTools.filter(t => t.data.type === 'plugin' && t.data.featured);

const schema = [
  {
    '@type': 'BreadcrumbList',
    'itemListElement': [
      { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': 'https://channel47.dev/' },
      { '@type': 'ListItem', 'position': 2, 'name': 'Plugins' },
    ],
  },
  {
    '@type': 'ItemList',
    'name': 'Claude Code Plugins by Role — Plugin Marketplace',
    'numberOfItems': plugins.length,
    'itemListElement': plugins.map((tool, i) => ({
      '@type': 'ListItem',
      'position': i + 1,
      'name': tool.data.name,
      'description': tool.data.description,
      'url': `https://channel47.dev/plugins/${tool.id.split('/').pop()?.replace(/\.md$/, '')}`,
    })),
  },
];
---

<BaseLayout
  title="Claude Code Plugins by Role — Media Buyer, Designer, Strategist | channel47"
  description="Free, open-source Claude Code plugins organized by professional role. Media buying, frontend design, and creative strategy — install with one command."
  schema={schema}
>
  <Nav />

  <main id="main-content">

    <!-- ═══════ HERO — LOW density ═══════ -->
    <section class="hero hero--compact" data-section="hero">
      <div class="hero__inner">
        <div class="hero__bar" aria-hidden="true"></div>
        <p class="label hero__label">Plugins</p>
        <h1 class="hero__headline max-w-[20ch]">One plugin per role.<br />Built from the work.</h1>
        <div class="install-block" data-section="install">
          <code class="install-block__cmd">claude plugin marketplace add channel47</code>
          <button
            class="install-block__copy"
            data-install="claude plugin marketplace add channel47"
            aria-label="Copy install command"
          >Copy</button>
        </div>
      </div>
    </section>

    <!-- ═══════ DEFINITION — AI-extractable answer block ═══════ -->
    <section class="py-[clamp(40px,6vh,60px)] border-t border-smoke" data-reveal>
      <div class="wrap">
        <p class="font-mono text-sm text-dust leading-[1.75] tracking-wide max-w-[600px]">
          channel47 plugins are free, open-source packages for Claude Code organized by professional role. Three plugins are live: Media Buyer (paid ads across Google, Bing, and Meta), Frontend Designer (UI design, build, and review), and Creative Strategist (customer research to creative angles). Built by Jackson Dean from real workflows — not theory.
        </p>
      </div>
    </section>

    <!-- ═══════ DIRECTORY — HIGH density ═══════ -->
    <section class="py-[clamp(60px,10vh,100px)]" data-reveal-stagger>
      <div class="wrap">
        <div class="flex items-baseline justify-between mb-6" data-reveal-child data-stagger="1">
          <p class="label">Directory</p>
          <span class="font-mono text-[11px] text-stone tracking-wide">{plugins.length} {plugins.length === 1 ? 'plugin' : 'plugins'}</span>
        </div>

        <div>
          {plugins.map((tool, i) => (
            <div data-reveal-child data-stagger={String(Math.min(i + 2, 6))}>
              <ToolCard
                name={tool.data.name}
                description={tool.data.description}
                type={tool.data.type}
                href={`/plugins/${tool.id.split('/').pop()?.replace(/\.md$/, '')}`}
                index={i + 1}
                status={tool.data.status}
              />
            </div>
          ))}
        </div>

        {plugins.length === 0 && (
          <p class="font-mono text-sm text-stone py-8">First plugins shipping soon.</p>
        )}
      </div>
    </section>

    <!-- ═══════ RUPTURE — LOW density, surface flip ═══════ -->
    <section class="rupture" data-reveal>
      <div class="max-w-[640px] mx-auto relative pl-8 px-[clamp(24px,5vw,64px)]">
        <div class="accent-bar-v" aria-hidden="true"></div>
        <p class="label text-ink/50 mb-2">Signal</p>
        <h2 class="font-display text-ink text-[clamp(1.5rem,3vw,2.25rem)] font-semibold tracking-tight leading-[1.15] mb-4">
          The media buyer plugin caught $3K/month in wasted spend. The creative strategist turned Reddit threads into production ad angles in ten minutes.
        </h2>
        <a class="font-mono text-[11px] font-semibold tracking-widest uppercase text-signal hover:text-signal-dim transition-colors duration-100" href="/plugins/media-buyer">
          See the Media Buyer plugin &rarr;
        </a>
      </div>
    </section>

    <!-- ═══════ SIGNUP — MEDIUM density ═══════ -->
    <section class="py-[clamp(80px,12vh,120px)]" data-reveal>
      <div class="wrap">
        <p class="label mb-5">Build Notes</p>
        <h2 class="section-headline mb-5">Plugin updates and build breakdowns, weekly.</h2>
        <EmailSignup placeholder="you@domain.com" tag="plugins" submitText="Get Build Notes" />
      </div>
    </section>

    <!-- ═══════ CTA VOID — LOW density ═══════ -->
    <section class="cta" data-reveal>
      <a class="cta__headline" href="/plugins/media-buyer">Try the Media Buyer plugin</a>
      <a href="/subscribe" class="btn-signal">Get Build Notes</a>
    </section>

    <Footer />
  </main>
</BaseLayout>


<style>
  .install-block {
    margin-top: 32px;
    opacity: 0;
  }
  :global(.hero.is-visible) .install-block {
    animation: fade-up 400ms var(--ease-out) 900ms forwards;
  }
  @media (prefers-reduced-motion: reduce) {
    .install-block { opacity: 1; }
  }
</style>
