---
/**
 * FrontEnd Craft — Landing page (sales).
 *
 * Density rhythm (page-compose):
 *   HIGH (hero) → HIGH (proof bar) → MEDIUM (problem) →
 *   HIGH (what's inside) → LOW (how it works) →
 *   MEDIUM (mechanism) → RUPTURE (price anchoring) →
 *   MEDIUM (FAQ) → LOW (CTA void)
 *
 * One rupture: light surface inversion at price section.
 * One CTA: "Download for $29" (appears 3×: hero, after mechanism, final).
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const faqs = [
  {
    q: 'I already have a design system.',
    a: 'Perfect. That\'s exactly who this is for. FrontEnd Craft reads your existing tokens and enforces them. If you have a Tailwind config, CSS custom properties, or a component library — the pattern-scout extracts your system and the design-critic holds generation accountable to it.',
  },
  {
    q: 'Can\'t I just tell Claude about my design tokens?',
    a: 'You can. Every session. Every time you start a new conversation. And the first time you forget — or Claude decides #3b82f6 looks better than your actual primary — you\'re back to fixing output by hand. FrontEnd Craft enforces tokens automatically. Install once, never re-explain.',
  },
  {
    q: '$29 seems too cheap. Is this real?',
    a: 'It\'s a zip file, not a SaaS. No servers. No infrastructure costs. No monthly billing system. $29 covers the craft that went into building 6 skills, 2 agents, and a hook system. You get the plugin forever.',
  },
  {
    q: 'What if Claude Code changes and breaks the plugin?',
    a: 'Plugins are the official Claude Code extension model — not a hack. FrontEnd Craft uses standard plugin APIs: skills (markdown), agents (markdown), and hooks (JSON). These are stable, documented interfaces. If something changes, you\'ll get updates.',
  },
];

const skills = [
  {
    name: 'design-system',
    desc: 'Generates .design-system.json with constraint budgets. Locks your palette, type scale, spacing, radii, shadows, and motion tiers.',
  },
  {
    name: 'component-craft',
    desc: 'Builds components with semantic HTML, cva variants, design tokens, and all four interactive states.',
  },
  {
    name: 'page-compose',
    desc: 'Assembles pages with density rhythm — HIGH, MEDIUM, LOW zones. Plans containers, grids, and one intentional rupture per page.',
  },
  {
    name: 'visual-review',
    desc: 'Five-layer review: spacing, typography, color, visual rhythm, and polish. Only reports issues at 70+ confidence.',
  },
  {
    name: 'accessibility',
    desc: 'WCAG audit across five layers: semantic HTML, keyboard nav, screen readers, color/contrast, and responsive.',
  },
  {
    name: 'polish',
    desc: 'Adds the final craft layer: interactive states, transitions, loading skeletons, empty states, error handling, and micro-interactions.',
  },
];

const agents = [
  {
    name: 'pattern-scout',
    desc: 'Explores your codebase before building anything. Extracts your existing colors, spacing, typography, and component patterns.',
  },
  {
    name: 'design-critic',
    desc: 'Reviews generated UI for visual quality and design consistency. Scores findings at 70+ confidence. Flags violations.',
  },
];

const constraints = [
  { label: 'Unique colors', budget: '12–15 max' },
  { label: 'Font families', budget: '2 max' },
  { label: 'Accent colors', budget: '1' },
  { label: 'Spacing scale', budget: 'Multiples of 4px' },
  { label: 'Border radii', budget: '3–4 values' },
  { label: 'Shadow levels', budget: '3–4' },
  { label: 'Motion durations', budget: '4 tiers' },
];

const schema = {
  '@type': 'Product',
  'name': 'FrontEnd Craft',
  'description': 'A Claude Code plugin that enforces your design tokens during AI generation. 6 skills, 2 agents, and hooks that catch violations.',
  'brand': { '@type': 'Organization', 'name': 'channel47' },
  'offers': {
    '@type': 'Offer',
    'price': '29',
    'priceCurrency': 'USD',
    'availability': 'https://schema.org/InStock',
  },
};
---

<BaseLayout
  title="FrontEnd Craft — Design System Enforcement for Claude Code"
  description="A Claude Code plugin that enforces your design tokens during AI generation. 6 skills, 2 agents, and hooks that catch violations. $29 one-time."
  schema={schema}
>
  <Nav />

  <main id="main-content">

    <!-- ═══════ HERO — HIGH density ═══════ -->
    <section class="hero is-visible">
      <div class="hero__inner">
        <div class="hero__bar" aria-hidden="true"></div>
        <p class="label hero__label">FrontEnd Craft</p>
        <h1 class="hero__headline">It's pretty.<br />But it's not yours.</h1>
        <p class="hero__sub">
          A Claude Code plugin that enforces your design system during generation.
          Your tokens. Your spacing scale. Your typography. Every component looks like
          it belongs to your product — not a template.
        </p>
        <div class="hero__cta">
          <a href="#download" class="btn-signal">Download for $29</a>
          <p class="hero__hint">One-time purchase. No subscription. Works in Claude Code and Cowork.</p>
        </div>
      </div>
    </section>

    <!-- ═══════ PROOF BAR — HIGH density ═══════ -->
    <section class="proof-bar" style="--proof-cols: 4;" data-reveal-stagger>
      <div class="proof-bar__item" data-reveal-child data-stagger="1">
        <span class="proof-bar__value proof-bar__value--signal">6</span>
        <span class="proof-bar__label">Skills</span>
      </div>
      <div class="proof-bar__item" data-reveal-child data-stagger="2">
        <span class="proof-bar__value">2</span>
        <span class="proof-bar__label">Agents</span>
      </div>
      <div class="proof-bar__item" data-reveal-child data-stagger="3">
        <span class="proof-bar__value">8</span>
        <span class="proof-bar__label">Phases</span>
      </div>
      <div class="proof-bar__item" data-reveal-child data-stagger="4">
        <span class="proof-bar__value proof-bar__value--signal">$29</span>
        <span class="proof-bar__label">Once. Forever.</span>
      </div>
    </section>

    <!-- ═══════ PROBLEM — MEDIUM density ═══════ -->
    <section class="py-[clamp(80px,14vh,140px)] border-t border-smoke" data-reveal>
      <div class="wrap">
        <p class="label mb-6">You know it when you see it</p>
        <div class="max-w-[620px]">
          <p class="fc-body mb-6">
            You asked Claude for a settings page. It gave you Inter, a purple-to-blue gradient,
            and <code class="fc-code">rounded-2xl</code> on everything.
          </p>
          <div class="fc-violations" data-reveal-stagger>
            <div class="fc-violation" data-reveal-child data-stagger="1">
              <span class="fc-violation__label">Spacing</span>
              <span class="fc-violation__bad">padding: 20px</span>
              <span class="fc-violation__arrow" aria-hidden="true">→</span>
              <span class="fc-violation__good">Your system uses 4px scale</span>
            </div>
            <div class="fc-violation" data-reveal-child data-stagger="2">
              <span class="fc-violation__label">Color</span>
              <span class="fc-violation__bad">#3b82f6</span>
              <span class="fc-violation__arrow" aria-hidden="true">→</span>
              <span class="fc-violation__good">Your primary is #E11D48</span>
            </div>
            <div class="fc-violation" data-reveal-child data-stagger="3">
              <span class="fc-violation__label">Type</span>
              <span class="fc-violation__bad">text-2xl</span>
              <span class="fc-violation__arrow" aria-hidden="true">→</span>
              <span class="fc-violation__good">Yours is text-xl font-semibold</span>
            </div>
          </div>
          <p class="fc-body mt-8">
            Now you're spending 20 minutes fixing what took 10 seconds to generate.
            Every inconsistent component makes the next one harder to get right.
            The spacing drifts. The colors multiply. The component families stop looking related.
          </p>
          <p class="fc-body-accent mt-4">
            This is design debt. And AI is generating it faster than you can clean it up.
          </p>
        </div>
      </div>
    </section>

    <!-- ═══════ WHAT'S INSIDE — HIGH density ═══════ -->
    <section class="py-[clamp(72px,12vh,120px)] border-t border-smoke" data-reveal-stagger>
      <div class="wrap">
        <p class="label mb-6" data-reveal-child data-stagger="1">What's inside</p>
        <h2 class="section-headline mb-10" data-reveal-child data-stagger="2">6 skills. 2 agents.<br />1 hook system.</h2>

        <!-- Skills grid -->
        <div class="fc-grid" data-reveal-child data-stagger="3">
          {skills.map((skill) => (
            <div class="fc-card">
              <span class="fc-card__name">{skill.name}</span>
              <p class="fc-card__desc">{skill.desc}</p>
            </div>
          ))}
        </div>

        <!-- Agents -->
        <div class="fc-agents" data-reveal-child data-stagger="4">
          {agents.map((agent) => (
            <div class="fc-agent">
              <span class="fc-agent__dot" aria-hidden="true"></span>
              <div>
                <span class="fc-agent__name">{agent.name}</span>
                <p class="fc-agent__desc">{agent.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Hooks -->
        <div class="fc-hooks" data-reveal-child data-stagger="5">
          <span class="fc-hooks__label">Hooks</span>
          <p class="fc-hooks__desc">
            Auto-flags hardcoded hex colors, pixel spacing values, and missing
            <code class="fc-code">focus-visible</code> styles during development.
            Silent when everything's clean. Warns when it's not.
          </p>
        </div>
      </div>
    </section>

    <!-- ═══════ HOW IT WORKS — LOW density ═══════ -->
    <section class="py-[clamp(80px,16vh,160px)] border-t border-smoke" data-reveal-stagger>
      <div class="wrap-narrow">
        <p class="label mb-6" data-reveal-child data-stagger="1">How it works</p>
        <h2 class="section-headline mb-12" data-reveal-child data-stagger="2">Three steps. One workflow.</h2>

        <div class="fc-steps" data-reveal-child data-stagger="3">
          <div class="fc-step">
            <span class="fc-step__num">01</span>
            <div>
              <h3 class="fc-step__title">Install</h3>
              <p class="fc-step__desc">Download the zip. Drop it in your Claude Code plugins directory. Done.</p>
            </div>
          </div>
          <div class="fc-step">
            <span class="fc-step__num">02</span>
            <div>
              <h3 class="fc-step__title">Run <code class="fc-code">/frontend-craft</code></h3>
              <p class="fc-step__desc">
                The plugin kicks off an 8-phase workflow: discovery, codebase exploration,
                design system check, layout planning, implementation, polish, review, and documentation.
                You choose which phases to run.
              </p>
            </div>
          </div>
          <div class="fc-step">
            <span class="fc-step__num">03</span>
            <div>
              <h3 class="fc-step__title">Ship consistent UI</h3>
              <p class="fc-step__desc">
                Every component uses your tokens. Every page follows your density rhythm.
                Every interactive element has all four states. The design-critic reviews
                the output before you push.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════ MECHANISM — MEDIUM density ═══════ -->
    <section class="py-[clamp(80px,14vh,140px)] border-t border-smoke" data-reveal-stagger>
      <div class="wrap">
        <p class="label mb-6" data-reveal-child data-stagger="1">The mechanism</p>
        <h2 class="section-headline mb-4" data-reveal-child data-stagger="2">Constraints, not suggestions.</h2>
        <p class="fc-body max-w-[560px] mb-10" data-reveal-child data-stagger="3">
          FrontEnd Craft generates a <code class="fc-code">.design-system.json</code> file
          that sets hard constraint budgets:
        </p>

        <!-- Constraint table -->
        <div class="fc-table" data-reveal-child data-stagger="4">
          <div class="fc-table__header">
            <span>Constraint</span>
            <span>Budget</span>
          </div>
          {constraints.map((c) => (
            <div class="fc-table__row">
              <span class="fc-table__label">{c.label}</span>
              <span class="fc-table__value">{c.budget}</span>
            </div>
          ))}
        </div>

        <div class="max-w-[620px] mt-12" data-reveal-child data-stagger="5">
          <p class="fc-body mb-6">
            The <strong class="text-chalk">pattern-scout</strong> agent reads your actual codebase before
            generating anything. It doesn't guess your design language — it extracts it.
            Existing colors, spacing values, typography, component patterns. All documented
            before a single line is written.
          </p>
          <p class="fc-body mb-6">
            The <strong class="text-chalk">design-critic</strong> agent reviews every output. Not a checkbox — a
            confidence-scored analysis across spacing, typography, color usage, interactive
            states, and pattern consistency. Findings below 70 aren't reported. Above 90 get
            flagged as "fix now."
          </p>
          <p class="fc-body-accent">
            Your design system isn't a suggestion Claude sometimes follows. It's the law.
          </p>
        </div>

        <div class="mt-10" data-reveal-child data-stagger="6">
          <a href="#download" class="btn-signal">Download for $29</a>
        </div>
      </div>
    </section>

    <!-- ═══════ RUPTURE — surface flip + price anchoring (LOW) ═══════ -->
    <section class="rupture" data-reveal>
      <div class="rupture__inner">
        <div class="rupture__bar"></div>
        <p class="label label--muted mb-5">Pricing</p>
        <h2 class="rupture__headline">$29. Once.</h2>
        <div class="fc-anchor">
          <div class="fc-anchor__row">
            <span class="fc-anchor__name">v0 Pro</span>
            <span class="fc-anchor__price fc-anchor__price--compared">$20/month</span>
          </div>
          <div class="fc-anchor__row">
            <span class="fc-anchor__name">Lovable</span>
            <span class="fc-anchor__price fc-anchor__price--compared">$50/month</span>
          </div>
          <div class="fc-anchor__row">
            <span class="fc-anchor__name">Design review (1 hr)</span>
            <span class="fc-anchor__price fc-anchor__price--compared">$150</span>
          </div>
          <div class="fc-anchor__row fc-anchor__row--highlight">
            <span class="fc-anchor__name">FrontEnd Craft</span>
            <span class="fc-anchor__price fc-anchor__price--signal">$29 once</span>
          </div>
        </div>
        <p class="fc-anchor__note">
          No subscription. No API keys. No servers. You own it forever.
        </p>
      </div>
    </section>

    <!-- ═══════ FAQ — MEDIUM density ═══════ -->
    <section class="py-[clamp(60px,10vh,100px)] border-t border-smoke" data-reveal-stagger>
      <div class="wrap">
        <p class="label mb-6" data-reveal-child data-stagger="1">Common questions</p>
        <div class="max-w-[672px]">
          {faqs.map((faq, i) => (
            <details class="faq-item border-b border-smoke" data-reveal-child data-stagger={String(Math.min(i + 2, 6))}>
              <summary class="faq-item__q">{faq.q}</summary>
              <div class="faq-item__a-wrap"><p class="faq-item__a">{faq.a}</p></div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════ CTA VOID — LOW density ═══════ -->
    <section class="cta" id="download" data-reveal>
      <h2 class="cta__headline">Stop fixing. Start enforcing.</h2>
      <p class="fc-body text-center max-w-[440px] mb-10">
        Your design system exists for a reason. FrontEnd Craft makes sure Claude respects it.
        <br /><br />
        6 skills. 2 agents. Hooks that catch violations in real time. One install.
      </p>
      <a href="#download" class="btn-signal">Download for $29</a>
      <p class="mt-3 text-[11px] font-mono tracking-wide text-stone">
        Zip file. Drop into Claude Code. Works immediately.
      </p>
    </section>

    <Footer />
  </main>
</BaseLayout>

<style>
  /* ═══════════════════════════════════════════
     FRONTEND CRAFT — page-specific styles
     Token-compliant (design-system skill)
     ═══════════════════════════════════════════ */

  /* ── Body text ── */
  .fc-body {
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-dust);
  }
  .fc-body-accent {
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-chalk);
    font-weight: 500;
  }

  /* ── Inline code ── */
  .fc-code {
    font-family: var(--font-family-mono);
    font-size: 13px;
    background: var(--color-soot);
    padding: 2px 6px;
    border-radius: var(--radius-tight);
    color: var(--color-bone);
  }

  /* ── Violations (problem section) ── */
  .fc-violations {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--color-smoke);
    border-radius: var(--radius-tight);
    overflow: hidden;
  }
  .fc-violation {
    display: grid;
    grid-template-columns: 72px 1fr auto 1fr;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--color-smoke);
    font-family: var(--font-family-mono);
    font-size: 12px;
    letter-spacing: 0.02em;
  }
  .fc-violation:last-child { border-bottom: none; }
  .fc-violation__label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-stone);
  }
  .fc-violation__bad {
    color: #ef4444;
    background: rgba(239, 68, 68, 0.08);
    padding: 2px 8px;
    border-radius: var(--radius-tight);
  }
  .fc-violation__arrow { color: var(--color-ash); }
  .fc-violation__good {
    color: var(--color-success);
    font-size: 11px;
  }

  @media (max-width: 640px) {
    .fc-violation {
      grid-template-columns: 1fr;
      gap: 4px;
      padding: 12px 16px;
    }
    .fc-violation__arrow { display: none; }
  }

  /* ── Skill/Agent cards (what's inside) ── */
  .fc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-smoke);
    border: 1px solid var(--color-smoke);
    border-radius: var(--radius-tight);
    overflow: hidden;
    margin-bottom: 24px;
  }
  .fc-card {
    background: var(--color-void);
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .fc-card__name {
    font-family: var(--font-family-mono);
    font-size: 13px;
    font-weight: 600;
    color: var(--color-signal);
    letter-spacing: 0.02em;
  }
  .fc-card__desc {
    font-family: var(--font-family-mono);
    font-size: 12px;
    line-height: 1.6;
    color: var(--color-dust);
    letter-spacing: 0.02em;
  }

  @media (max-width: 768px) {
    .fc-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .fc-grid { grid-template-columns: 1fr; }
  }

  /* ── Agents ── */
  .fc-agents {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--color-smoke);
    border-radius: var(--radius-tight);
    overflow: hidden;
    margin-bottom: 24px;
  }
  .fc-agent {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 16px 20px;
    border-bottom: 1px solid var(--color-smoke);
  }
  .fc-agent:last-child { border-bottom: none; }
  .fc-agent__dot {
    width: 8px;
    height: 8px;
    min-width: 8px;
    border-radius: 50%;
    background: var(--color-signal);
    margin-top: 5px;
  }
  .fc-agent__name {
    font-family: var(--font-family-mono);
    font-size: 13px;
    font-weight: 600;
    color: var(--color-chalk);
    letter-spacing: 0.02em;
  }
  .fc-agent__desc {
    font-family: var(--font-family-mono);
    font-size: 12px;
    line-height: 1.6;
    color: var(--color-dust);
    margin-top: 4px;
    letter-spacing: 0.02em;
  }

  /* ── Hooks ── */
  .fc-hooks {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 16px 20px;
    border: 1px solid var(--color-smoke);
    border-radius: var(--radius-tight);
    background: var(--color-soot);
  }
  .fc-hooks__label {
    font-family: var(--font-family-mono);
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-signal);
    padding: 3px 8px;
    border: 1px solid var(--color-signal);
    border-radius: var(--radius-tight);
    white-space: nowrap;
    margin-top: 1px;
  }
  .fc-hooks__desc {
    font-family: var(--font-family-mono);
    font-size: 12px;
    line-height: 1.6;
    color: var(--color-dust);
    letter-spacing: 0.02em;
  }

  /* ── Steps (how it works) ── */
  .fc-steps {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .fc-step {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    padding: 24px 0;
    border-bottom: 1px solid var(--color-smoke);
  }
  .fc-step:first-child { border-top: 1px solid var(--color-smoke); }
  .fc-step__num {
    font-family: var(--font-family-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--color-signal);
    margin-top: 3px;
    min-width: 24px;
  }
  .fc-step__title {
    font-family: var(--font-family-display);
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-chalk);
    margin-bottom: 6px;
  }
  .fc-step__desc {
    font-family: var(--font-family-mono);
    font-size: 13px;
    line-height: 1.7;
    color: var(--color-dust);
    letter-spacing: 0.02em;
  }

  /* ── Constraint table (mechanism) ── */
  .fc-table {
    max-width: 440px;
    border: 1px solid var(--color-smoke);
    border-radius: var(--radius-tight);
    overflow: hidden;
  }
  .fc-table__header {
    display: flex;
    justify-content: space-between;
    padding: 10px 16px;
    background: var(--color-soot);
    font-family: var(--font-family-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-stone);
    border-bottom: 1px solid var(--color-smoke);
  }
  .fc-table__row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 16px;
    border-bottom: 1px solid var(--color-smoke);
    font-family: var(--font-family-mono);
    font-size: 13px;
    letter-spacing: 0.02em;
  }
  .fc-table__row:last-child { border-bottom: none; }
  .fc-table__label { color: var(--color-bone); }
  .fc-table__value {
    color: var(--color-signal);
    font-size: 12px;
    font-weight: 500;
  }

  /* ── Price anchoring (rupture) ── */
  .fc-anchor {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: 360px;
    width: 100%;
