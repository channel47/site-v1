---
import BaseLayout from '../layouts/BaseLayout.astro';
import LogoAnimated from '../components/LogoAnimated.astro';
import EmailSignup from '../components/EmailSignup.astro';
---

<BaseLayout title="CH47 Design System" noindex={true}>
  <main id="main-content" class="brand-page">
    <div class="brand-wrap">

      <!-- Header -->
      <header class="brand-header">
        <div class="brand-header__logo">
          <LogoAnimated />
        </div>
        <div>
          <h1 class="brand-header__title">CH47 Design System</h1>
          <p class="brand-header__sub">Brand guidelines and component reference for channel47.dev</p>
        </div>
      </header>

      <hr class="divider" />

      <!-- ═══════════════ COLORS ═══════════════ -->
      <section class="brand-section" id="colors">
        <p class="label">Colors</p>
        <h2>Color Palette</h2>
        <p class="brand-section__desc">Warm amber accent on warm cream. Neutrals are warm gray (not pure gray). The dark panel surface uses rgba white overlays for text hierarchy.</p>

        <h3>Primary (Amber)</h3>
        <div class="swatch-row">
          <div class="swatch" style="background: var(--color-primary-50);">
            <span class="swatch__label">50</span>
            <span class="swatch__hex">#fffbf0</span>
          </div>
          <div class="swatch" style="background: var(--color-primary-100);">
            <span class="swatch__label">100</span>
            <span class="swatch__hex">#fff3d6</span>
          </div>
          <div class="swatch" style="background: var(--color-primary-200);">
            <span class="swatch__label">200</span>
            <span class="swatch__hex">#ffe5a8</span>
          </div>
          <div class="swatch" style="background: var(--color-primary-300);">
            <span class="swatch__label">300</span>
            <span class="swatch__hex">#fdd574</span>
          </div>
          <div class="swatch" style="background: var(--color-primary-400);">
            <span class="swatch__label">400</span>
            <span class="swatch__hex">#fcc94d</span>
          </div>
          <div class="swatch swatch--dark-text" style="background: var(--color-primary-500);">
            <span class="swatch__label">500</span>
            <span class="swatch__hex">#fcaa2d</span>
          </div>
          <div class="swatch swatch--dark-text" style="background: var(--color-primary-600);">
            <span class="swatch__label">600</span>
            <span class="swatch__hex">#e08c10</span>
          </div>
          <div class="swatch swatch--light-text" style="background: var(--color-primary-700);">
            <span class="swatch__label">700</span>
            <span class="swatch__hex">#b87008</span>
          </div>
          <div class="swatch swatch--light-text" style="background: var(--color-primary-800);">
            <span class="swatch__label">800</span>
            <span class="swatch__hex">#945a06</span>
          </div>
          <div class="swatch swatch--light-text" style="background: var(--color-primary-900);">
            <span class="swatch__label">900</span>
            <span class="swatch__hex">#7a4a05</span>
          </div>
        </div>

        <h3>Neutral (Warm Gray)</h3>
        <div class="swatch-row">
          <div class="swatch" style="background: var(--color-neutral-50);">
            <span class="swatch__label">50</span>
            <span class="swatch__hex">#fffef2</span>
          </div>
          <div class="swatch" style="background: var(--color-neutral-100);">
            <span class="swatch__label">100</span>
            <span class="swatch__hex">#faf9f0</span>
          </div>
          <div class="swatch" style="background: var(--color-neutral-200);">
            <span class="swatch__label">200</span>
            <span class="swatch__hex">#f0efe4</span>
          </div>
          <div class="swatch" style="background: var(--color-neutral-300);">
            <span class="swatch__label">300</span>
            <span class="swatch__hex">#dddcd2</span>
          </div>
          <div class="swatch" style="background: var(--color-neutral-400);">
            <span class="swatch__label">400</span>
            <span class="swatch__hex">#a8a79e</span>
          </div>
          <div class="swatch swatch--light-text" style="background: var(--color-neutral-500);">
            <span class="swatch__label">500</span>
            <span class="swatch__hex">#73726a</span>
          </div>
          <div class="swatch swatch--light-text" style="background: var(--color-neutral-600);">
            <span class="swatch__label">600</span>
            <span class="swatch__hex">#55544d</span>
          </div>
          <div class="swatch swatch--light-text" style="background: var(--color-neutral-700);">
            <span class="swatch__label">700</span>
            <span class="swatch__hex">#3d3c36</span>
          </div>
          <div class="swatch swatch--light-text" style="background: var(--color-neutral-800);">
            <span class="swatch__label">800</span>
            <span class="swatch__hex">#2a2a24</span>
          </div>
          <div class="swatch swatch--light-text" style="background: var(--color-neutral-900);">
            <span class="swatch__label">900</span>
            <span class="swatch__hex">#191918</span>
          </div>
          <div class="swatch swatch--light-text" style="background: var(--color-neutral-950);">
            <span class="swatch__label">950</span>
            <span class="swatch__hex">#0d0d0c</span>
          </div>
        </div>

        <h3>Semantic</h3>
        <div class="swatch-row">
          <div class="swatch swatch--light-text" style="background: var(--color-success);">
            <span class="swatch__label">Success</span>
            <span class="swatch__hex">#28C840</span>
          </div>
          <div class="swatch swatch--light-text" style="background: var(--color-destructive);">
            <span class="swatch__label">Destructive</span>
            <span class="swatch__hex">#e5453a</span>
          </div>
          <div class="swatch swatch--dark-text" style="background: var(--color-warning);">
            <span class="swatch__label">Warning</span>
            <span class="swatch__hex">#f59e0b</span>
          </div>
          <div class="swatch swatch--light-text" style="background: var(--color-info);">
            <span class="swatch__label">Info</span>
            <span class="swatch__hex">#3b82f6</span>
          </div>
        </div>

        <h3>Dark Panel Surface</h3>
        <div class="panel-demo">
          <div class="panel-demo__row">
            <span style="color: var(--color-panel-fg);">panel-fg (0.85)</span>
            <span style="color: var(--color-panel-fg-muted);">panel-fg-muted (0.6)</span>
            <span style="color: var(--color-panel-fg-dim);">panel-fg-dim (0.5)</span>
            <span style="color: var(--color-panel-dim);">panel-dim (0.35)</span>
          </div>
          <hr style="border: none; height: 1px; background: var(--color-panel-divider); margin: 16px 0;" />
          <div class="panel-demo__row" style="gap: 12px;">
            <span style="background: var(--color-panel-tint); padding: 4px 12px; border-radius: var(--radius-xs);">tint (0.05)</span>
            <span style="background: var(--color-panel-tint-hover); padding: 4px 12px; border-radius: var(--radius-xs);">tint-hover (0.08)</span>
            <span style="border: 1px solid var(--color-panel-border); padding: 4px 12px; border-radius: var(--radius-xs);">border (0.15)</span>
            <span style="border: 1px solid var(--color-panel-divider); padding: 4px 12px; border-radius: var(--radius-xs);">divider (0.10)</span>
          </div>
        </div>
      </section>

      <hr class="divider" />

      <!-- ═══════════════ TYPOGRAPHY ═══════════════ -->
      <section class="brand-section" id="typography">
        <p class="label">Typography</p>
        <h2>Type System</h2>
        <p class="brand-section__desc">Geist for body and headings. Geist Mono for labels, buttons, code, and data. Light-first with warm gray body text.</p>

        <div class="type-samples">
          <div class="type-sample">
            <span class="type-sample__label">H1 — Geist 700, clamp(2.25rem, 5vw, 3.75rem), tracking -0.03em</span>
            <h1 style="font-size: clamp(2.25rem, 5vw, 3.75rem); font-weight: 700; line-height: 1.05; letter-spacing: -0.03em; color: var(--color-fg);">DTC Google Ads, meet Claude.</h1>
          </div>

          <div class="type-sample">
            <span class="type-sample__label">H2 — Geist 600, 1.5rem, tracking -0.02em</span>
            <h2 style="font-size: 1.5rem; font-weight: 600; line-height: 1.2; letter-spacing: -0.02em; color: var(--color-fg);">Section Heading</h2>
          </div>

          <div class="type-sample">
            <span class="type-sample__label">H3 — Geist 600, 1.125rem, tracking -0.01em</span>
            <h3 style="font-size: 1.125rem; font-weight: 600; line-height: 1.3; letter-spacing: -0.01em; color: var(--color-fg);">Subsection Heading</h3>
          </div>

          <div class="type-sample">
            <span class="type-sample__label">Body — Geist 400, 15px, line-height 1.6</span>
            <p style="color: var(--color-neutral-700);">Two open-source plugins built from $6M+ in real DTC spend. Campaign architecture, daily optimization, customer research to creative — install and go.</p>
          </div>

          <div class="type-sample">
            <span class="type-sample__label">Body Muted — color-fg-muted</span>
            <p style="color: var(--color-fg-muted);">Frameworks from real DTC accounts — not blog posts, not theory.</p>
          </div>

          <div class="type-sample">
            <span class="type-sample__label">Label — Geist Mono 500, 11px, uppercase, tracking 0.15em</span>
            <p class="label">Open-Source Claude Plugins</p>
          </div>

          <div class="type-sample">
            <span class="type-sample__label">Mono Body — Geist Mono 400, 13px</span>
            <p style="font-family: var(--font-mono); font-size: 13px; color: var(--color-fg-muted);">claude plugin install ctrlswing/dtc-google-ads-playbook</p>
          </div>
        </div>
      </section>

      <hr class="divider" />

      <!-- ═══════════════ BUTTONS ═══════════════ -->
      <section class="brand-section" id="buttons">
        <p class="label">Components</p>
        <h2>Buttons</h2>
        <p class="brand-section__desc">Three variants (primary, secondary, ghost) and three sizes (sm, md, lg). Mono uppercase text with tight letter-spacing. All buttons have hover, active, focus-visible, and disabled states.</p>

        <h3>Variants</h3>
        <div class="component-row">
          <button class="btn btn--primary">Primary</button>
          <button class="btn btn--secondary">Secondary</button>
          <button class="btn btn--ghost">Ghost</button>
          <button class="btn btn--primary" disabled>Disabled</button>
        </div>

        <h3>Sizes</h3>
        <div class="component-row">
          <button class="btn btn--primary btn--sm">Small</button>
          <button class="btn btn--primary">Medium</button>
          <button class="btn btn--primary btn--lg">Large</button>
        </div>
      </section>

      <hr class="divider" />

      <!-- ═══════════════ BADGES ═══════════════ -->
      <section class="brand-section" id="badges">
        <h2>Badges</h2>
        <p class="brand-section__desc">Pill-shaped labels for tags, status indicators, and categories.</p>

        <div class="component-row">
          <span class="badge badge--default">Default</span>
          <span class="badge badge--primary">Google Ads</span>
          <span class="badge badge--success">Active</span>
          <span class="badge badge--destructive">Deprecated</span>
        </div>
      </section>

      <hr class="divider" />

      <!-- ═══════════════ CARDS ═══════════════ -->
      <section class="brand-section" id="cards">
        <h2>Cards</h2>
        <p class="brand-section__desc">Light surface cards with border. Hover state adds shadow and darkens border.</p>

        <div class="card-grid">
          <div class="card">
            <p class="label" style="margin-bottom: 12px;">Plugin</p>
            <h3 style="font-size: 1.125rem; font-weight: 600; color: var(--color-fg); margin-bottom: 8px;">DTC Google Ads Playbook</h3>
            <p style="font-size: 14px; color: var(--color-fg-muted); line-height: 1.6; margin-bottom: 16px;">Campaign architecture, daily optimization, ad copy, and landing pages. Built from real DTC accounts.</p>
            <div class="component-row" style="gap: 6px;">
              <span class="badge badge--primary">Google Ads</span>
              <span class="badge badge--default">MIT</span>
            </div>
          </div>

          <div class="card">
            <p class="label" style="margin-bottom: 12px;">Plugin</p>
            <h3 style="font-size: 1.125rem; font-weight: 600; color: var(--color-fg); margin-bottom: 8px;">DTC Research Engine</h3>
            <p style="font-size: 14px; color: var(--color-fg-muted); line-height: 1.6; margin-bottom: 16px;">5-stage pipeline: customer research, personas, angles, copy, scripts. Full creative pipeline.</p>
            <div class="component-row" style="gap: 6px;">
              <span class="badge badge--primary">Research</span>
              <span class="badge badge--default">MIT</span>
            </div>
          </div>

          <div class="card card--flat">
            <p class="label label--muted" style="margin-bottom: 12px;">Flat Variant</p>
            <h3 style="font-size: 1.125rem; font-weight: 600; color: var(--color-fg); margin-bottom: 8px;">No Border Card</h3>
            <p style="font-size: 14px; color: var(--color-fg-muted); line-height: 1.6;">Uses a subtle background fill instead of a border. Good for grids where borders create too much visual noise.</p>
          </div>
        </div>
      </section>

      <hr class="divider" />

      <!-- ═══════════════ CODE ═══════════════ -->
      <section class="brand-section" id="code">
        <h2>Code</h2>
        <p class="brand-section__desc">Inline code for references in body text. Code blocks for install commands and examples.</p>

        <h3>Inline</h3>
        <p>Install the plugin with <code class="code">claude plugin install</code> and start using it immediately.</p>

        <h3>Code Block</h3>
        <div>
          <div class="code-block__header">
            <span>Terminal</span>
          </div>
          <pre class="code-block">claude plugin install ctrlswing/dtc-google-ads-playbook</pre>
        </div>
      </section>

      <hr class="divider" />

      <!-- ═══════════════ EMAIL FORMS ═══════════════ -->
      <section class="brand-section" id="email">
        <h2>Email Signup</h2>
        <p class="brand-section__desc">Three variants for different contexts. All share the same submission logic and state management.</p>

        <h3>Inline (Hero)</h3>
        <EmailSignup variant="inline" placeholder="you@company.com" tag="brand-page" submitText="Join the Community" />

        <h3>Default</h3>
        <EmailSignup variant="default" placeholder="your@email.com" tag="brand-page" submitText="Join the Community" />

        <h3>Prominent</h3>
        <EmailSignup variant="prominent" placeholder="your@email.com" tag="brand-page" submitText="Join the Community" />
      </section>

      <hr class="divider" />

      <!-- ═══════════════ RADIUS & SHADOWS ═══════════════ -->
      <section class="brand-section" id="radius">
        <h2>Radius & Shadows</h2>

        <h3>Border Radius</h3>
        <div class="component-row" style="gap: 24px; flex-wrap: wrap;">
          <div class="radius-demo" style="border-radius: var(--radius-xs);"><span>xs (3px)</span></div>
          <div class="radius-demo" style="border-radius: var(--radius-sm);"><span>sm (6px)</span></div>
          <div class="radius-demo" style="border-radius: var(--radius-md);"><span>md (8px)</span></div>
          <div class="radius-demo" style="border-radius: var(--radius-lg);"><span>lg (10px)</span></div>
          <div class="radius-demo" style="border-radius: var(--radius-xl);"><span>xl (16px)</span></div>
          <div class="radius-demo" style="border-radius: var(--radius-2xl);"><span>2xl (24px)</span></div>
          <div class="radius-demo" style="border-radius: var(--radius-full);"><span>full</span></div>
        </div>

        <h3>Shadows</h3>
        <div class="component-row" style="gap: 24px; flex-wrap: wrap;">
          <div class="shadow-demo" style="box-shadow: var(--shadow-subtle);"><span>subtle</span></div>
          <div class="shadow-demo" style="box-shadow: var(--shadow-medium);"><span>medium</span></div>
          <div class="shadow-demo" style="box-shadow: var(--shadow-elevated);"><span>elevated</span></div>
          <div class="shadow-demo" style="box-shadow: var(--shadow-card);"><span>card</span></div>
        </div>
      </section>

      <hr class="divider" />

      <!-- ═══════════════ MOTION ═══════════════ -->
      <section class="brand-section" id="motion">
        <h2>Motion</h2>
        <p class="brand-section__desc">Two easing curves and three timing tokens. All motion respects <code class="code">prefers-reduced-motion: reduce</code>.</p>

        <div class="token-table">
          <div class="token-table__row">
            <span class="token-table__key">--ease-out</span>
            <span class="token-table__val">cubic-bezier(0.16, 1, 0.3, 1)</span>
            <span class="token-table__desc">Default for most transitions. Quick start, gentle land.</span>
          </div>
          <div class="token-table__row">
            <span class="token-table__key">--ease-sharp</span>
            <span class="token-table__val">cubic-bezier(0.33, 1, 0.68, 1)</span>
            <span class="token-table__desc">Snappier. Use for active/pressed states.</span>
          </div>
          <div class="token-table__row">
            <span class="token-table__key">--dur-instant</span>
            <span class="token-table__val">100ms</span>
            <span class="token-table__desc">Color changes, opacity flips. Should feel immediate.</span>
          </div>
          <div class="token-table__row">
            <span class="token-table__key">--dur-quick</span>
            <span class="token-table__val">200ms</span>
            <span class="token-table__desc">Hover states, focus rings, border transitions.</span>
          </div>
          <div class="token-table__row">
            <span class="token-table__key">--dur-measured</span>
            <span class="token-table__val">400ms</span>
            <span class="token-table__desc">Entrance animations, reveal transitions.</span>
          </div>
        </div>
      </section>

      <hr class="divider" />

      <!-- ═══════════════ DARK PANEL ═══════════════ -->
      <section class="brand-section" id="dark-panel">
        <h2>Dark Panel</h2>
        <p class="brand-section__desc">The hero card uses a dark panel surface. Components on dark surfaces use the panel token scale for text, borders, and tints.</p>

        <div class="dark-panel-demo">
          <p class="label" style="color: var(--color-primary-500); margin-bottom: 16px;">On Dark Surface</p>
          <h3 style="font-size: 1.5rem; font-weight: 700; color: var(--color-panel-fg); margin-bottom: 8px;">Headline on Panel</h3>
          <p style="color: var(--color-panel-fg-muted); margin-bottom: 20px; line-height: 1.6;">Body text uses panel-fg-muted for comfortable reading on dark surfaces. Panel-dim is for decorative or tertiary content.</p>
          <div style="display: flex; gap: 12px; flex-wrap: wrap;">
            <button class="btn btn--primary">Primary Action</button>
            <button class="btn btn--ghost" style="color: var(--color-panel-fg-dim); border-color: var(--color-panel-border);">Ghost on Dark</button>
          </div>
        </div>
      </section>

      <!-- Footer -->
      <footer class="brand-footer">
        <span style="color: var(--color-fg-dim);">channel47.dev/brand</span>
        <span style="color: var(--color-fg-dim);">by <a href="https://x.com/ctrlswing" target="_blank" rel="noopener noreferrer" style="color: var(--color-fg-muted); transition: color var(--dur-instant) var(--ease-sharp);">ctrlswing</a></span>
      </footer>

    </div>
  </main>
</BaseLayout>

<style>
  /* ── Page layout ── */
  .brand-page {
    padding: clamp(24px, 4vw, 64px) clamp(16px, 4vw, 40px);
  }

  .brand-wrap {
    max-width: 960px;
    margin: 0 auto;
  }

  /* ── Header ── */
  .brand-header {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 48px;
  }

  .brand-header__logo {
    flex-shrink: 0;
  }

  .brand-header__title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-fg);
    letter-spacing: -0.02em;
  }

  .brand-header__sub {
    font-size: 14px;
    color: var(--color-fg-muted);
    margin-top: 4px;
  }

  /* ── Sections ── */
  .brand-section {
    padding: 48px 0;
  }

  .brand-section h2 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-fg);
    letter-spacing: -0.02em;
    margin-top: 12px;
    margin-bottom: 8px;
  }

  .brand-section h3 {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-fg);
    margin-top: 32px;
    margin-bottom: 16px;
  }

  .brand-section__desc {
    font-size: 15px;
    color: var(--color-fg-muted);
    line-height: 1.6;
    max-width: 60ch;
    margin-bottom: 24px;
  }

  .brand-section p {
    line-height: 1.6;
  }

  /* ── Color swatches ── */
  .swatch-row {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
  }

  .swatch {
    flex: 1;
    min-width: 72px;
    height: 80px;
    border-radius: var(--radius-sm);
    padding: 8px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    border: 1px solid var(--color-border);
  }

  .swatch__label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    opacity: 0.7;
  }

  .swatch__hex {
    font-family: var(--font-mono);
    font-size: 9px;
    opacity: 0.6;
  }

  .swatch--dark-text .swatch__label,
  .swatch--dark-text .swatch__hex {
    color: var(--color-neutral-900);
  }

  .swatch--light-text .swatch__label,
  .swatch--light-text .swatch__hex {
    color: rgba(255, 255, 255, 0.85);
  }

  /* ── Panel demo ── */
  .panel-demo {
    background: var(--color-panel);
    border-radius: var(--radius-lg);
    padding: 24px;
    font-family: var(--font-mono);
    font-size: 12px;
  }

  .panel-demo__row {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    color: var(--color-panel-fg);
  }

  /* ── Type samples ── */
  .type-samples {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .type-sample__label {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-fg-dim);
    margin-bottom: 8px;
    letter-spacing: 0.02em;
  }

  /* ── Component demos ── */
  .component-row {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
  }

  /* ── Radius demos ── */
  .radius-demo {
    width: 80px;
    height: 80px;
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    display: flex;
