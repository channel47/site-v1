---
/**
 * Guides Hub — practitioner guides for Claude + paid media.
 * Density: LOW (hero) → MEDIUM (guides grid) → LOW (rupture signup) → LOW (cta void)
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import EmailSignup from '../../components/EmailSignup.astro';

const guides = (await getCollection('guides', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categoryOrder = ['overview', 'setup', 'workflow', 'comparison'] as const;

const schema = [
  {
    '@type': 'BreadcrumbList',
    'itemListElement': [
      { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': 'https://channel47.dev/' },
      { '@type': 'ListItem', 'position': 2, 'name': 'Guides' },
    ],
  },
  {
    '@type': 'ItemList',
    'name': 'Claude Code Plugin Guides',
    'numberOfItems': guides.length,
    'itemListElement': guides.map((guide, i) => ({
      '@type': 'ListItem',
      'position': i + 1,
      'name': guide.data.title,
      'url': `https://channel47.dev/guides/${guide.id.replace(/\.md$/, '')}`,
    })),
  },
];
---

<BaseLayout
  title="Guides — Claude Code Plugin Setup, Workflows & Best Practices | channel47"
  description="Practitioner guides for Claude Code plugins. Setup walkthroughs, workflow breakdowns, and real examples from media buying, design, and creative strategy."
  schema={schema}
>
  <Nav />
  <main id="main-content">

    <!-- HERO -->
    <section class="hero hero--compact" data-section="hero">
      <div class="hero__inner">
        <div class="hero__bar" aria-hidden="true"></div>
        <p class="label hero__label">Guides</p>
        <h1 class="hero__headline max-w-[20ch]">Guides from the build.</h1>
        <p class="hero__sub">
          Setup walkthroughs, workflow breakdowns, and real examples. Every guide links to the plugin that makes it work.
        </p>
      </div>
    </section>

    <!-- DEFINITION — AI-extractable answer block -->
    <section class="py-[clamp(40px,6vh,60px)] border-t border-smoke" data-reveal>
      <div class="wrap">
        <p class="font-mono text-sm text-dust leading-[1.75] tracking-wide max-w-[600px]">
          channel47 guides show practitioners how to use Claude Code plugins for media buying, frontend design, and creative strategy. Topics include connecting ad accounts, running workflows, and getting value from day one. All plugins are free and open source. Built by Jackson Dean from real workflows.
        </p>
      </div>
    </section>

    <!-- GUIDES GRID -->
    <section class="py-[clamp(60px,10vh,100px)]" data-reveal-stagger>
      <div class="wrap">
        <div class="flex items-baseline justify-between mb-6" data-reveal-child data-stagger="1">
          <p class="label">All Guides</p>
          <span class="font-mono text-[11px] text-stone tracking-wide">{guides.length} {guides.length === 1 ? 'guide' : 'guides'}</span>
        </div>

        <div class="max-w-[672px]">
          {guides.map((guide, i) => {
            const slug = guide.id.replace(/\.md$/, '');
            const formatted = guide.data.date.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'short',
              day: 'numeric',
            });
            const catLabel = guide.data.category.toUpperCase();
            const isSetup = guide.data.category === 'setup';
            return (
              <a
                href={`/guides/${slug}`}
                class="card-link block py-5 border-b border-smoke group"
                data-reveal-child
                data-stagger={String(Math.min(i + 2, 6))}
              >
                <div class="w-6 h-0.5 bg-signal/40 mb-3 transition-all duration-200 group-hover:w-10 group-hover:bg-signal" aria-hidden="true"></div>
                <div class="flex items-center gap-3 mb-2">
                  <span class:list={[
                    'font-mono text-[10px] font-semibold tracking-[0.15em] uppercase px-2 py-0.5 rounded-tight',
                    isSetup ? 'bg-[var(--signal-dim-alpha)] text-signal' : 'bg-soot text-stone'
                  ]}>{catLabel}</span>
                  <span class="w-px h-3 bg-ash" aria-hidden="true"></span>
                  <time class="font-mono text-[11px] text-stone tracking-wide" datetime={guide.data.date.toISOString()}>{formatted}</time>
                </div>
                <h3 class="font-display text-[clamp(1.1rem,2vw,1.35rem)] font-semibold tracking-[-0.02em] text-chalk mb-1 group-hover:text-signal transition-colors duration-150">{guide.data.title}</h3>
                <p class="font-mono text-[13px] text-dust leading-relaxed tracking-wide line-clamp-2">{guide.data.description}</p>
              </a>
            );
          })}
        </div>

        {guides.length === 0 && (
          <p class="font-mono text-sm text-stone py-8">First guides shipping soon.</p>
        )}
      </div>
    </section>

    <!-- RUPTURE -->
    <section class="rupture" data-reveal>
      <div class="max-w-[640px] mx-auto relative pl-8 px-[clamp(24px,5vw,64px)]">
        <div class="accent-bar-v" aria-hidden="true"></div>
        <p class="label text-ink/50 mb-2">Signal</p>
        <h2 class="font-display text-ink text-[clamp(1.5rem,3vw,2.25rem)] font-semibold tracking-tight leading-[1.15] mb-4">
          A pacing alert flagged a budget overrun four days before the client noticed.
        </h2>
        <a class="font-mono text-[11px] font-semibold tracking-widest uppercase text-signal hover:text-signal-dim transition-colors duration-100" href="/plugins/google-ads">
          See the Google Ads plugin &rarr;
        </a>
      </div>
    </section>

    <!-- SIGNUP -->
    <section class="py-[clamp(80px,12vh,120px)]" data-reveal>
      <div class="wrap">
        <p class="label mb-5">Build Notes</p>
        <h2 class="section-headline mb-5">New guides and workflow updates, weekly.</h2>
        <EmailSignup placeholder="you@domain.com" tag="guides" submitText="Get Build Notes" />
      </div>
    </section>

    <!-- CTA VOID -->
    <section class="cta" data-reveal>
      <a class="cta__headline" href="/plugins">Browse the plugins</a>
      <a href="/subscribe" class="btn-signal">Get Build Notes</a>
    </section>

    <Footer />
  </main>
</BaseLayout>

