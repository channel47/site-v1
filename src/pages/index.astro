---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import LogoAnimated from '../components/LogoAnimated.astro';
import EmailSignup from '../components/EmailSignup.astro';

const SKOOL_LINK = 'https://www.skool.com/the-vibe-marketers/about?ref=a005b4a2e4e9420e814a94e5e1c2e708';

const links = [
  { label: 'Plugins', href: '/plugins', desc: 'Claude plugins for paid media' },
  { label: 'Guides', href: '/guides', desc: 'Practitioner how-tos' },
  { label: 'Notes', href: '/notes', desc: 'Build log & newsletter' },
  { label: 'Vibe Marketers', href: SKOOL_LINK, desc: 'Skool community', external: true },
];

const schema = [
  {
    '@type': 'Organization',
    'name': 'Channel 47',
    'url': 'https://channel47.dev',
    'logo': 'https://channel47.dev/logo-square.png',
    'description': 'Plugins, experiments, and resources for builders using AI professionally.',
    'founder': {
      '@type': 'Person',
      'name': 'Jackson Dean',
      'url': 'https://x.com/ctrlswing',
    },
    'sameAs': [
      'https://github.com/channel47',
      'https://x.com/ctrlswing',
    ],
  },
  {
    '@type': 'WebSite',
    'name': 'Channel 47',
    'url': 'https://channel47.dev',
  },
];
---

<BaseLayout
  title="Channel 47 — Plugins, experiments, and resources"
  description="Playground for Claude plugins, practitioner guides, and AI experiments. Built by ctrlswing."
  schema={schema}
>
  <Nav />

  <main id="main-content" class="home">
    <div class="home__inner">

      <div class="home__logo">
        <LogoAnimated class="home__logo-glyph" />
      </div>

      <p class="home__pitch">
        Plugins, experiments, and resources.<br />
        <span class="text-stone">A playground by <a href="https://x.com/ctrlswing" target="_blank" rel="noopener" class="home__attr">ctrlswing</a>.</span>
      </p>

      <div class="home__signup">
        <p class="home__signup-label">Get notified when something ships.</p>
        <EmailSignup
          variant="inline"
          placeholder="your@email.com"
          submitText="→"
          tag="home"
        />
      </div>

      <nav class="home__links" aria-label="Resources">
        {links.map((link, i) => (
          <a
            href={link.href}
            class="home__link"
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener' : undefined}
            style={`--delay: ${i * 80}ms`}
          >
            <span class="home__link-label">{link.label}</span>
            <span class="home__link-desc">{link.desc}</span>
            <span class="home__link-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </nav>

    </div>

    <Footer />
  </main>
</BaseLayout>

<style>
  .home {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  .home__inner {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
    padding: clamp(100px, 16vh, 160px) clamp(24px, 5vw, 64px) clamp(60px, 10vh, 100px);
  }

  .home__logo {
    margin-bottom: 40px;
  }
  .home__logo :global(.logo-animated) {
    font-size: 22px;
  }

  .home__pitch {
    font-family: var(--font-family-mono);
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-bone);
    letter-spacing: 0.02em;
    margin-bottom: 48px;
  }
  .home__attr {
    color: var(--color-stone);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--color-ash);
    transition: color 100ms var(--ease-sharp);
  }
  .home__attr:hover {
    color: var(--color-signal);
  }

  .home__signup {
    width: 100%;
    max-width: 400px;
    margin-bottom: 56px;
  }
  .home__signup-label {
    font-family: var(--font-family-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-stone);
    margin-bottom: 12px;
  }

  .home__links {
    width: 100%;
    max-width: 400px;
    display: flex;
    flex-direction: column;
  }
  .home__link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: baseline;
    gap: 12px;
    padding: 14px 0;
    border-bottom: 1px solid var(--color-smoke);
    text-decoration: none;
    transition: background-color 100ms var(--ease-out);
    animation: fade-up 400ms var(--ease-out) var(--delay, 0ms) both;
  }
  .home__link:first-child {
    border-top: 1px solid var(--color-smoke);
  }
  .home__link:hover {
    background-color: rgba(245, 158, 11, 0.03);
  }
  .home__link-label {
    font-family: var(--font-family-mono);
    font-size: 13px;
    font-weight: 500;
    color: var(--color-bone);
    transition: color 100ms var(--ease-sharp);
  }
  .home__link:hover .home__link-label {
    color: var(--color-signal);
  }
  .home__link-desc {
    font-family: var(--font-family-mono);
    font-size: 11px;
    color: var(--color-stone);
    text-align: right;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .home__link-arrow {
    font-family: var(--font-family-mono);
    font-size: 12px;
    color: var(--color-ash);
    transition: color 100ms var(--ease-sharp), transform 100ms var(--ease-out);
  }
  .home__link:hover .home__link-arrow {
    color: var(--color-signal);
    transform: translateX(2px);
  }

  @media (max-width: 480px) {
    .home__link {
      grid-template-columns: auto 1fr auto;
    }
    .home__link-desc {
      display: none;
    }
  }
</style>
