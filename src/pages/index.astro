---
/**
 * Homepage — Role-based Claude plugins.
 *
 * Density: LOW (hero) → HIGH (proof bar) → HIGH (plugin directory) →
 *          MEDIUM (credibility) → RUPTURE → MEDIUM (FAQ) → LOW (CTA void)
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import EmailSignup from '../components/EmailSignup.astro';
import ToolCard from '../components/ToolCard.astro';

const allTools = await getCollection('tools');
const plugins = allTools.filter(t => t.data.type === 'plugin' && t.data.featured);

const faqs = [
  {
    q: 'What is channel47?',
    a: 'channel47 builds free, open-source Claude Code plugins organized by professional role — media buyer, frontend designer, creative strategist. Each plugin packages real workflows into skills, commands, and agents that activate automatically when you\'re working. Built by Jackson Dean from running ad accounts and building products daily.',
  },
  {
    q: 'What is a Claude Code plugin?',
    a: 'A plugin extends what Claude can do. It bundles skills (knowledge that auto-activates), commands (workflows you invoke), and agents (autonomous sub-tasks) into one installable package. No code required — plugins are markdown files that teach Claude your process.',
  },
  {
    q: 'Are channel47 plugins free?',
    a: 'Yes. All channel47 plugins are free and open source (MIT license). Three plugins are live: Media Buyer (paid ads across Google, Bing, and Meta), Frontend Designer (UI design and build), and Creative Strategist (customer research to creative angles).',
  },
  {
    q: 'Do I need API keys?',
    a: 'Depends on the plugin. Media Buyer connects to ad platform APIs and needs credentials for Google Ads, Bing Ads, or Meta Ads. Frontend Designer and Creative Strategist need nothing — install and start using immediately.',
  },
  {
    q: 'How do I install a plugin?',
    a: 'In Claude Code, run: claude plugin install media-buyer@channel47 (or frontend-designer@channel47, or creative-strategist@channel47). The plugin activates immediately.',
  },
];

const schema = [
  {
    '@type': 'Organization',
    'name': 'channel47',
    'url': 'https://channel47.dev',
    'logo': 'https://channel47.dev/logo-square.png',
    'description': 'Free, open-source Claude Code plugins organized by professional role. Media buying, frontend design, and creative strategy — built from real work, not theory.',
    'founder': {
      '@type': 'Person',
      'name': 'Jackson Dean',
      'url': 'https://x.com/ctrlswing',
      'jobTitle': 'Marketer & Plugin Builder',
    },
    'sameAs': [
      'https://github.com/channel47',
      'https://x.com/ctrlswing',
    ],
  },
  {
    '@type': 'WebSite',
    'name': 'channel47',
    'url': 'https://channel47.dev',
  },
  {
    '@type': 'FAQPage',
    'mainEntity': faqs.map(f => ({
      '@type': 'Question',
      'name': f.q,
      'acceptedAnswer': {
        '@type': 'Answer',
        'text': f.a,
      },
    })),
  },
];
---

<BaseLayout
  title="Claude Code Plugins by Role — Media Buyer, Designer, Strategist | channel47"
  description="Free, open-source Claude Code plugins organized by professional role. Media buying across Google/Bing/Meta, frontend design, and creative strategy — built from real work."
  schema={schema}
>
  <Nav />

  <main id="main-content">

    <!-- ═══════ HERO — LOW density ═══════ -->
    <section class="hero is-visible">
      <div class="hero__inner">
        <div class="hero__bar" aria-hidden="true"></div>
        <p class="label hero__label">Transmitting</p>
        <h1 class="hero__headline">Plugins that know<br />your job.</h1>
        <p class="hero__sub">
          Open-source Claude Code plugins organized by role. Media buying, frontend design, creative strategy — built from the work, not the docs.
        </p>
        <div class="hero__cta">
          <div class="install-block">
            <code class="install-block__cmd">claude plugin marketplace add channel47</code>
            <button
              class="install-block__copy"
              data-install="claude plugin marketplace add channel47"
              aria-label="Copy install command"
            >Copy</button>
          </div>
          <div class="hero__secondary">
            <a href="/plugins" class="hero__browse">Browse plugins →</a>
            <span class="hero__sep" aria-hidden="true"></span>
            <a href="/subscribe" class="hero__subscribe">Get Build Notes</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════ PROOF BAR — HIGH density ═══════ -->
    <section class="proof-bar" data-reveal-stagger>
      <div class="proof-bar__item" data-reveal-child data-stagger="1">
        <span class="proof-bar__value" data-counter="3">3</span>
        <span class="proof-bar__label">Plugins Live</span>
      </div>
      <div class="proof-bar__item" data-reveal-child data-stagger="2">
        <span class="proof-bar__value" data-counter="3">3</span>
        <span class="proof-bar__label">Roles Covered</span>
      </div>
      <div class="proof-bar__item" data-reveal-child data-stagger="3">
        <span class="proof-bar__value">MIT</span>
        <span class="proof-bar__label">Licensed</span>
      </div>
      <div class="proof-bar__item" data-reveal-child data-stagger="4">
        <span class="proof-bar__value">Weekly</span>
        <span class="proof-bar__label">Build Notes</span>
      </div>
    </section>

    <!-- ═══════ PLUGIN DIRECTORY — HIGH density ═══════ -->
    <section class="directory" data-reveal-stagger>
      <div class="wrap">
        <div class="directory__header" data-reveal-child data-stagger="1">
          <h2 class="directory__title">The plugins</h2>
          <a href="/plugins" class="directory__link">View all →</a>
        </div>

        <ul class="directory__list" data-reveal-child data-stagger="2">
          {plugins.map((tool, i) => (
            <ToolCard
              name={tool.data.name}
              description={tool.data.description}
              type={tool.data.type}
              href={`/plugins/${tool.id.split('/').pop()?.replace(/\.md$/, '')}`}
              index={i + 1}
              variant="compact"
              status={tool.data.status}
            />
          ))}
        </ul>
      </div>
    </section>

    <!-- ═══════ CREDIBILITY — MEDIUM density ═══════ -->
    <section class="credibility" data-reveal>
      <div class="wrap">
        <p class="label">Built from the work, not the docs</p>
        <p class="credibility__body">
          The media buyer plugin caught ~$3K/month in wasted ad spend across two accounts. The creative strategist was built from the same research pipeline that produced angles for a $6M+ Google Ads account. Every plugin here comes from real workflows — not a lab.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/guides" class="credibility__link">Read the guides →</a>
          <a href="/notes" class="credibility__link">Follow the build notes →</a>
        </div>
      </div>
    </section>

    <!-- ═══════ FAQ — MEDIUM density ═══════ -->
    <section class="py-[clamp(60px,10vh,100px)] border-t border-smoke" data-reveal-stagger>
      <div class="wrap">
        <p class="label mb-6" data-reveal-child data-stagger="1">Common questions</p>
        <div class="max-w-[672px]">
          {faqs.map((faq, i) => (
            <details class="faq-item border-b border-smoke" data-reveal-child data-stagger={String(Math.min(i + 2, 6))}>
              <summary class="faq-item__q">{faq.q}</summary>
              <p class="faq-item__a">{faq.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════ RUPTURE — surface flip + density shift (LOW) ═══════ -->
    <section class="rupture" data-reveal>
      <div class="rupture__inner">
        <div class="rupture__bar"></div>
        <p class="label label--muted mb-5">Signal</p>
        <h2 class="rupture__headline">One plugin caught $3K/month in wasted spend. Another turned Reddit threads into production ad angles in under ten minutes.</h2>
        <a href="/plugins" class="rupture__link">Browse the plugins →</a>
      </div>
    </section>

    <!-- ═══════ EMAIL CAPTURE — MEDIUM density ═══════ -->
    <section class="py-[clamp(60px,10vh,100px)] border-t border-smoke" data-reveal>
      <div class="wrap max-w-[600px]">
        <p class="label mb-5">Build Notes</p>
        <h2 class="section-headline mb-4">Weekly breakdowns from building plugins in production.</h2>
        <p class="font-mono text-sm text-dust leading-[1.75] tracking-wide mb-8">
          What worked, what broke, what I'd do differently. No theory.
        </p>
        <EmailSignup tag="home" />
      </div>
    </section>

    <!-- ═══════ CTA VOID — LOW density ═══════ -->
    <section class="cta" data-reveal>
      <a href="/plugins" class="cta__headline">Browse the plugins.</a>
      <a href="/subscribe" class="btn-signal">Get Build Notes</a>
    </section>

    <Footer />
  </main>
</BaseLayout>


<style>
  .hero__secondary {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 20px;
  }
  .hero__browse,
  .hero__subscribe {
    font-family: var(--font-family-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.05em;
    transition: color 100ms var(--ease-sharp);
  }
  .hero__browse { color: var(--color-dust); }
  .hero__browse:hover { color: var(--color-signal); }
  .hero__subscribe { color: var(--color-signal); }
  .hero__subscribe:hover { color: var(--color-signal-hover); }
  .hero__browse:focus-visible,
  .hero__subscribe:focus-visible {
    outline: 2px solid var(--color-signal);
    outline-offset: 4px;
    border-radius: var(--radius-tight);
  }
  .hero__sep {
    width: 1px;
    height: 12px;
    background: var(--color-ash);
    flex-shrink: 0;
  }
</style>
