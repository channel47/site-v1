---
import BaseLayout from '../layouts/BaseLayout.astro';
import LogoAnimated from '../components/LogoAnimated.astro';
import EmailSignup from '../components/EmailSignup.astro';
---

<BaseLayout title="Channel 47 — Claude Plugins for DTC Media Buyers">
  <main id="main-content" class="hero-card-page">

    <div class="hero-card">
      <!-- Header -->
      <header class="hero-card__header">
        <div class="hero-card__brand">
          <LogoAnimated />
        </div>
      </header>

      <!-- Main 2-column grid -->
      <div class="hero-card__main">

        <!-- Left: Hero content -->
        <section class="hero-card__hero">
          <div class="hero-card__hero-content">
            <div class="hero-card__bar" aria-hidden="true"></div>
            <p class="hero-card__label">Open-Source Claude Plugins</p>
            <h1 class="hero-card__headline">DTC Google&nbsp;Ads,<br>meet Claude.</h1>
          </div>
          <div class="hero-card__hero-bottom">
            <p class="hero-card__sub">
              Two open-source plugins built from $6M+ in real DTC spend. Campaign architecture, daily optimization, customer research to creative — install and go.
            </p>
            <div class="hero-card__cta">
              <EmailSignup
                variant="inline"
                placeholder="you@company.com"
                tag="homepage"
                submitText="Join the Community"
              />
              <p class="hero-card__hint">Early access to new plugins and DTC playbooks.</p>
            </div>
          </div>
        </section>

        <!-- Right: Metrics grid -->
        <section class="hero-card__metrics" data-reveal-stagger aria-label="Key metrics">
          <div class="hero-card__metric-row">
            <article class="hero-card__cell" data-reveal-child data-stagger="1">
              <div class="hero-card__cell-top">
                <svg class="hero-card__icon" viewBox="0 0 24 24" aria-hidden="true">
                  <rect x="3" y="3" width="7" height="7" rx="1" />
                  <rect x="14" y="3" width="7" height="7" rx="1" />
                  <rect x="3" y="14" width="7" height="7" rx="1" />
                  <path d="M14 17.5h7M17.5 14v7" stroke-linecap="round" />
                </svg>
                <span class="hero-card__number" data-counter="2">0</span>
              </div>
              <div class="hero-card__cell-content">
                <h3>Free Plugins</h3>
                <p>A Google Ads playbook and a research-to-creative engine. Open-source, MIT-licensed.</p>
              </div>
            </article>

            <article class="hero-card__cell" data-reveal-child data-stagger="2">
              <div class="hero-card__cell-top">
                <svg class="hero-card__icon" viewBox="0 0 24 24" aria-hidden="true">
                  <polyline points="22 7 13.5 15.5 8.5 10.5 2 17" />
                  <polyline points="16 7 22 7 22 13" />
                </svg>
                <span class="hero-card__number">$6M+</span>
              </div>
              <div class="hero-card__cell-content">
                <h3>In Managed Spend</h3>
                <p>Frameworks from real DTC accounts — not blog posts, not theory.</p>
              </div>
            </article>
          </div>

          <div class="hero-card__metric-row">
            <article class="hero-card__cell" data-reveal-child data-stagger="3">
              <div class="hero-card__cell-top">
                <svg class="hero-card__icon" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
                </svg>
                <span class="hero-card__number">0</span>
              </div>
              <div class="hero-card__cell-content">
                <h3>Setup Required</h3>
                <p>No API keys, no servers, no environment variables. Install and use.</p>
              </div>
            </article>

            <article class="hero-card__cell" data-reveal-child data-stagger="4">
              <div class="hero-card__cell-top">
                <svg class="hero-card__icon" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <span class="hero-card__number" data-counter="5">0</span>
              </div>
              <div class="hero-card__cell-content">
                <h3>Research Stages</h3>
                <p>Customer research → personas → angles → copy → scripts. Full pipeline.</p>
              </div>
            </article>
          </div>
        </section>

      </div>

      <!-- Footer -->
      <footer class="hero-card__footer">
        <div class="hero-card__footer-icons">
          <a href="https://github.com/ctrlswing" target="_blank" rel="noopener noreferrer" class="hero-card__footer-icon" aria-label="GitHub">
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
          </a>
          <a href="https://x.com/ctrlswing" target="_blank" rel="noopener noreferrer" class="hero-card__footer-icon" aria-label="X (Twitter)">
            <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        </div>
        <span>by <a href="https://x.com/ctrlswing" target="_blank" rel="noopener noreferrer" class="hero-card__footer-link">ctrlswing</a></span>
      </footer>
    </div>

  </main>
</BaseLayout>

<style>
  /* ── Page body ── */
  .hero-card-page {
    background: var(--color-neutral-100);
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    min-height: 100dvh;
    padding: clamp(16px, 4vw, 40px);
  }

  /* ── Card container ── */
  .hero-card {
    background: var(--color-panel);
    width: 100%;
    max-width: 1400px;
    min-height: 800px;
    border-radius: 24px;
    box-shadow: 0 40px 80px -20px rgba(25, 25, 24, 0.3);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    position: relative;
  }

  /* ── Header ── */
  .hero-card__header {
    display: flex;
    align-items: center;
    padding: 32px 48px 0;
  }

  .hero-card__brand {
    display: flex;
    align-items: center;
  }

  /* ── Logo inversion for dark surface ── */
  .hero-card :global(.logo-animated) {
    color: rgba(255, 255, 255, 0.85);
    --logo-glow: rgba(252, 170, 45, 0.4);
  }

  /* ── Main grid ── */
  .hero-card__main {
    display: grid;
    grid-template-columns: 40% 60%;
    flex-grow: 1;
  }

  /* ── Hero (left column) ── */
  .hero-card__hero {
    padding: 48px;
    border-right: 1px solid rgba(255, 255, 255, 0.10);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: clamp(40px, 6vh, 80px);
  }

  .hero-card__bar {
    width: 0;
    height: 2px;
    background: var(--color-primary-500);
    margin-bottom: 20px;
    animation: hero-card-draw-h 500ms var(--ease-out) 200ms forwards;
  }

  .hero-card__label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-primary-500);
    margin-bottom: 20px;
    opacity: 0;
    animation: hero-card-fade-in 300ms var(--ease-out) 450ms forwards;
  }

  .hero-card__headline {
    font-family: var(--font-heading);
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: rgba(255, 255, 255, 0.92);
    opacity: 0;
    clip-path: inset(0 50% 0 50%);
    animation: hero-card-clip-reveal 600ms var(--ease-out) 550ms forwards;
  }

  .hero-card__sub {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.6);
    max-width: 44ch;
    opacity: 0;
    animation: hero-card-fade-up 400ms var(--ease-out) 850ms forwards;
  }

  .hero-card__cta {
    margin-top: 28px;
    opacity: 0;
    animation: hero-card-fade-up 400ms var(--ease-out) 1050ms forwards;
  }

  .hero-card__hint {
    font-family: var(--font-mono);
    font-size: 11px;
    color: rgba(255, 255, 255, 0.35);
    margin-top: 10px;
    letter-spacing: 0.02em;
  }

  /* ── Email form dark overrides ── */
  .hero-card :global(.email-form) {
    max-width: 460px;
    gap: 0;
  }

  .hero-card :global(.email-form__input) {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-right: none;
    color: rgba(255, 255, 255, 0.9);
    font-family: var(--font-body);
    font-size: 15px;
    height: 52px;
    padding: 0 18px;
    border-radius: var(--radius-sm) 0 0 var(--radius-sm);
  }
  .hero-card :global(.email-form__input::placeholder) {
    color: rgba(255, 255, 255, 0.28);
  }
  .hero-card :global(.email-form__input:focus) {
    background: rgba(255, 255, 255, 0.08);
    border-color: var(--color-primary-500);
    box-shadow: 0 0 0 3px rgba(252, 170, 45, 0.12);
  }

  .hero-card :global(.email-form__btn) {
    background: var(--color-primary-500);
    color: var(--color-neutral-950);
    border: 1px solid var(--color-primary-500);
    height: 52px;
    padding: 0 28px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    animation: hero-card-btn-glow 2s var(--ease-out) 2s both;
  }
  .hero-card :global(.email-form__btn:hover) {
    background: var(--color-primary-400);
    box-shadow: 0 4px 20px rgba(252, 170, 45, 0.3);
  }

  /* Success state override for dark context */
  .hero-card :global(.email-signup.is-success .email-form__input) {
    border-color: var(--color-success);
  }
  .hero-card :global(.email-signup.is-success .email-form__btn) {
    background: var(--color-success);
    border-color: var(--color-success);
  }

  /* ── Metrics grid (right column) ── */
  .hero-card__metrics {
    display: grid;
    grid-template-rows: 1fr 1fr;
  }

  .hero-card__metric-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-bottom: 1px solid rgba(255, 255, 255, 0.10);
  }
  .hero-card__metric-row:last-child {
    border-bottom: none;
  }

  /* ── Individual metric cell ── */
  .hero-card__cell {
    padding: 36px;
    border-right: 1px solid rgba(255, 255, 255, 0.10);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 24px;
    transition: background-color 200ms var(--ease-out);
  }
  .hero-card__cell:last-child {
    border-right: none;
  }
  .hero-card__cell:hover {
    background: rgba(255, 255, 255, 0.03);
  }

  .hero-card__cell-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .hero-card__icon {
    width: 28px;
    height: 28px;
    stroke: rgba(255, 255, 255, 0.3);
    stroke-width: 1.5;
    fill: none;
    flex-shrink: 0;
  }

  .hero-card__number {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 400;
    line-height: 1;
    color: rgba(255, 255, 255, 0.85);
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
  }

  .hero-card__cell-content h3 {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-primary-500);
    margin-bottom: 6px;
  }

  .hero-card__cell-content p {
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.5);
  }

  /* ── Footer ── */
  .hero-card__footer {
    padding: 24px 48px;
    border-top: 1px solid rgba(255, 255, 255, 0.10);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 12px;
    color: rgba(255, 255, 255, 0.3);
    letter-spacing: 0.02em;
  }

  .hero-card__footer-icons {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .hero-card__footer-icon {
    color: rgba(255, 255, 255, 0.3);
    transition: color var(--dur-instant) var(--ease-sharp);
    display: flex;
    align-items: center;
  }
  .hero-card__footer-icon:hover { color: rgba(255, 255, 255, 0.7); }
  .hero-card__footer-icon:focus-visible {
    outline: 2px solid var(--color-primary-500);
    outline-offset: 2px;
    border-radius: var(--radius-xs);
  }

  .hero-card__footer-link {
    color: rgba(255, 255, 255, 0.3);
    transition: color var(--dur-instant) var(--ease-sharp);
  }
  .hero-card__footer-link:hover { color: var(--color-primary-500); }
  .hero-card__footer-link:focus-visible {
    outline: 2px solid var(--color-primary-500);
    outline-offset: 2px;
    border-radius: var(--radius-xs);
  }

  /* ── Keyframes (scoped to this card) ── */
  @keyframes hero-card-draw-h {
    from { width: 0; }
    to { width: 40px; }
  }

  @keyframes hero-card-fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes hero-card-clip-reveal {
    from { opacity: 0; clip-path: inset(0 50% 0 50%); }
    to { opacity: 1; clip-path: inset(0 0 0 0); }
  }

  @keyframes hero-card-fade-up {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes hero-card-btn-glow {
    0% { box-shadow: 0 0 0 0 rgba(252, 170, 45, 0); }
    50% { box-shadow: 0 0 20px 4px rgba(252, 170, 45, 0.2); }
    100% { box-shadow: none; }
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .hero-card__main {
      grid-template-columns: 1fr;
    }
    .hero-card__hero {
      border-right: none;
      border-bottom: 1px solid rgba(255, 255, 255, 0.10);
    }
    .hero-card {
      min-height: auto;
      border-radius: 20px;
    }
    .hero-card__header,
    .hero-card__hero,
    .hero-card__footer {
      padding-left: 36px;
      padding-right: 36px;
    }
    .hero-card__cell {
      padding: 28px;
    }
  }

  @media (max-width: 768px) {
    .hero-card {
      border-radius: 16px;
    }
    .hero-card__header {
      padding: 24px 24px;
    }
    .hero-card__hero {
      padding: 32px 24px;
    }
    .hero-card__cell {
      padding: 24px;
    }
    .hero-card__footer {
      padding: 20px 24px;
    }

    /* Stack email form on mobile */
    .hero-card :global(.email-form) {
      flex-direction: column;
      gap: 10px;
    }
    .hero-card :global(.email-form__input) {
      border-right: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: var(--radius-sm);
      height: 50px;
    }
    .hero-card :global(.email-form__btn) {
      border-radius: var(--radius-sm);
      width: 100%;
      height: 50px;
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .hero-card__metric-row {
      grid-template-columns: 1fr;
    }
    .hero-card__cell {
      border-right: none;
      border-bottom: 1px solid rgba(255, 255, 255, 0.10);
    }
    .hero-card__metric-row:last-child .hero-card__cell:last-child {
      border-bottom: none;
    }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .hero-card__bar {
      width: 40px;
      animation: none;
    }
    .hero-card__label,
    .hero-card__headline,
    .hero-card__sub,
    .hero-card__cta {
      opacity: 1;
      transform: none;
      clip-path: none;
      animation: none;
    }
  }
</style>
