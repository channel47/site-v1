---
/**
 * Homepage — AI skills for marketers who build.
 *
 * Density: LOW (hero) → HIGH (proof bar) → HIGH (skills directory) →
 *          MEDIUM (credibility) → MEDIUM (workshop callout) →
 *          RUPTURE → MEDIUM (product) → LOW (CTA void)
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import EmailSignup from '../components/EmailSignup.astro';
import ProductCallout from '../components/ProductCallout.astro';
import ToolCard from '../components/ToolCard.astro';

const SKOOL_LINK = 'https://www.skool.com/the-vibe-marketers/about?ref=a005b4a2e4e9420e814a94e5e1c2e708';

const allTools = await getCollection('tools');
const skills = allTools.filter(t => t.data.type === 'skill');

const faqs = [
  {
    q: 'What is Channel 47?',
    a: 'Channel 47 is a free, open-source platform that builds AI skills and plugins for marketers who build. Each skill is a focused AI workflow you can install with one command. Every tool is built by Jackson Dean from managing 25+ ad accounts daily.',
  },
  {
    q: "What's the difference between a skill and a plugin?",
    a: 'A skill is a single, focused AI workflow — install it and run it today. A plugin bundles multiple skills, API connections, and safety hooks into one package for a specific ad platform. Skills are the entry point. Plugins are the depth layer.',
  },
  {
    q: 'Are Channel 47 skills free?',
    a: 'Yes. All Channel 47 skills and plugins are free and open source on GitHub. The paid-search plugin (Google Ads and Bing Ads) is live at v7.0.0 with six skills included. PaidBrief, a commercial product built from the same ecosystem, is available separately at paidbrief.com.',
  },
  {
    q: 'What ad platforms does Channel 47 support?',
    a: 'Channel 47 currently supports Google Ads and Bing Ads through the paid-search plugin, which includes six skills and two MCP servers for live API access. Meta Ads (Facebook and Instagram) and TikTok Ads plugins are in active development.',
  },
  {
    q: 'How do I install a skill?',
    a: 'In Claude Code, run: npx skills add channel47/skills --skill [skill-name]. For the full plugin with all skills bundled, run: /plugin marketplace add channel47/plugins, then /plugin install paid-search@channel47.',
  },
];

const schema = [
  {
    '@type': 'Organization',
    'name': 'Channel 47',
    'url': 'https://channel47.dev',
    'logo': 'https://channel47.dev/logo-square.png',
    'description': 'Free AI skills and plugins for marketers who build. Install a skill and run it today, or learn to build your own at monthly workshops. Built from managing 25+ ad accounts daily.',
    'founder': {
      '@type': 'Person',
      'name': 'Jackson Dean',
      'url': 'https://x.com/ctrlswing',
      'jobTitle': 'Marketer & Skill Builder',
    },
    'sameAs': [
      'https://github.com/channel47',
      'https://x.com/ctrlswing',
    ],
  },
  {
    '@type': 'WebSite',
    'name': 'Channel 47',
    'url': 'https://channel47.dev',
  },
  {
    '@type': 'FAQPage',
    'mainEntity': faqs.map(f => ({
      '@type': 'Question',
      'name': f.q,
      'acceptedAnswer': {
        '@type': 'Answer',
        'text': f.a,
      },
    })),
  },
];
---

<BaseLayout
  title="AI Skills for Marketers — Channel 47"
  description="Free AI skills for marketers who build. Install and run today, or learn to build your own at monthly workshops. Built from managing 25+ ad accounts daily."
  schema={schema}
>
  <Nav />

  <main id="main-content">

    <!-- ═══════ HERO — LOW density ═══════ -->
    <section class="hero is-visible">
      <div class="hero__inner">
        <div class="hero__bar" aria-hidden="true"></div>
        <p class="label hero__label">Transmitting</p>
        <h1 class="hero__headline">AI skills for<br />marketers who build.</h1>
        <p class="hero__sub">
          Install a skill. Run it today. Or come to a workshop and build your own.
        </p>
        <div class="hero__cta">
          <EmailSignup variant="inline" placeholder="you@domain.com" tag="home" submitText="Get Build Notes" />
          <p class="hero__hint">Join 500+ marketers and builders. One email a week.</p>
        </div>
      </div>
    </section>

    <!-- ═══════ PROOF BAR — HIGH density ═══════ -->
    <section class="proof-bar" data-reveal-stagger>
      <div class="proof-bar__item" data-reveal-child data-stagger="1">
        <span class="proof-bar__value" data-counter="16">16<span class="text-signal">+</span></span>
        <span class="proof-bar__label">Skills Shipped</span>
      </div>
      <div class="proof-bar__item" data-reveal-child data-stagger="2">
        <span class="proof-bar__value" data-counter="25">25<span class="text-signal">+</span></span>
        <span class="proof-bar__label">Accounts Managed Daily</span>
      </div>
      <div class="proof-bar__item" data-reveal-child data-stagger="3">
        <span class="proof-bar__value">Monthly</span>
        <span class="proof-bar__label">Live Workshops</span>
      </div>
      <div class="proof-bar__item" data-reveal-child data-stagger="4">
        <span class="proof-bar__value">Weekly</span>
        <span class="proof-bar__label">Build Notes</span>
      </div>
    </section>

    <!-- ═══════ SKILLS DIRECTORY — HIGH density ═══════ -->
    <section class="directory" data-reveal-stagger>
      <div class="wrap">
        <div class="directory__header" data-reveal-child data-stagger="1">
          <h2 class="directory__title">Browse the skills</h2>
          <a href="/skills" class="directory__link">View all →</a>
        </div>

        <ul class="directory__list" data-reveal-child data-stagger="2">
          {skills.map((tool, i) => (
            <ToolCard
              name={tool.data.name}
              description={tool.data.description}
              type={tool.data.type}
              href={`/skills/${tool.id.split('/').pop()?.replace(/\.md$/, '')}`}
              index={i + 1}
              variant="compact"
              status={tool.data.status}
            />
          ))}
        </ul>

        <div class="mt-6" data-reveal-child data-stagger="3">
          <a href="/plugins" class="font-mono text-[11px] font-semibold tracking-widest uppercase text-stone hover:text-signal transition-colors duration-100">
            Go deeper → See the plugins
          </a>
        </div>
      </div>
    </section>

    <!-- ═══════ CREDIBILITY — MEDIUM density ═══════ -->
    <section class="credibility" data-reveal>
      <div class="wrap">
        <p class="label">Built from the work, not the docs</p>
        <p class="credibility__body">
          The paid-search plugin caught ~$3K/month in wasted spend across two accounts. A pacing alert flagged a budget overrun four days before the client noticed. Every tool here comes from managing 25+ accounts daily — not a lab.
        </p>
        <a href="/notes" class="credibility__link">Follow the build notes →</a>
      </div>
    </section>

    <!-- ═══════ WORKSHOP CALLOUT — MEDIUM density ═══════ -->
    <section class="py-[clamp(60px,10vh,100px)] border-t border-smoke" data-reveal>
      <div class="wrap">
        <div class="accent-bar" aria-hidden="true"></div>
        <p class="label mt-5 mb-5">Skill Remix Lab</p>
        <h2 class="section-headline mb-4">Monthly live build. One hour. You leave with a working skill.</h2>
        <p class="font-mono text-sm text-dust leading-[1.75] tracking-wide max-w-[600px] mb-6">
          Next session inside the Vibe Marketers community.
        </p>
        <a
          class="font-mono text-[11px] font-semibold tracking-widest uppercase text-signal hover:text-[#D97706] transition-colors duration-100"
          href={SKOOL_LINK}
          target="_blank"
          rel="noopener"
        >
          Join the next Lab &rarr;
        </a>
      </div>
    </section>

    <!-- ═══════ FAQ — MEDIUM density ═══════ -->
    <section class="py-[clamp(60px,10vh,100px)] border-t border-smoke" data-reveal-stagger>
      <div class="wrap">
        <p class="label mb-6" data-reveal-child data-stagger="1">Common questions</p>
        <div class="max-w-[672px]">
          {faqs.map((faq, i) => (
            <details class="faq-item border-b border-smoke" data-reveal-child data-stagger={String(Math.min(i + 2, 6))}>
              <summary class="faq-item__q">{faq.q}</summary>
              <p class="faq-item__a">{faq.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════ RUPTURE — surface flip + density shift (LOW) ═══════ -->
    <section class="rupture" data-reveal>
      <div class="rupture__inner">
        <div class="rupture__bar"></div>
        <p class="label label--muted mb-5">Signal</p>
        <h2 class="rupture__headline">The people who build skills become the most valuable people in their field.</h2>
        <a href="/skills" class="rupture__link">Browse the skills →</a>
      </div>
    </section>

    <!-- ═══════ PRODUCT CALLOUT — MEDIUM density ═══════ -->
    <ProductCallout />

    <!-- ═══════ CTA VOID — LOW density ═══════ -->
    <section class="cta" data-reveal>
      <a href="/skills" class="cta__headline">Browse the skills.</a>
      <a href="/subscribe" class="btn-signal">Get Build Notes</a>
    </section>

    <Footer />
  </main>
</BaseLayout>
