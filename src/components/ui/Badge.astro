---
/**
 * Badge — shared badge component.
 * Variants: default (soot bg), outline (border + dust), signal (amber bg), muted (border + stone).
 */
interface Props {
  variant?: 'default' | 'outline' | 'signal' | 'muted';
  class?: string;
}

const { variant = 'default', class: className } = Astro.props;

const variantClasses: Record<string, string> = {
  default: 'bg-soot text-stone',
  outline: 'border border-ash text-dust',
  signal: 'bg-signal text-void font-semibold',
  muted: 'border border-smoke text-stone',
};
---

<span
  data-slot="badge"
  class:list={[
    'font-mono text-[var(--text-badge)] tracking-[0.12em] uppercase px-2 py-0.5 rounded-tight inline-block',
    variantClasses[variant],
    className,
  ]}
><slot /></span>
