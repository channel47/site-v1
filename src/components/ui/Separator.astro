---
/**
 * Separator — horizontal divider or vertical pipe.
 */
interface Props {
  orientation?: 'horizontal' | 'vertical';
  class?: string;
}

const { orientation = 'horizontal', class: className } = Astro.props;
---

{orientation === 'horizontal' ? (
  <div role="separator" data-slot="separator" class:list={['h-px bg-smoke', className]} aria-hidden="true" />
) : (
  <span role="separator" data-slot="separator" class:list={['w-px h-3 bg-ash', className]} aria-hidden="true" />
)}
