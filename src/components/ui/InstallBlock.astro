---
/**
 * InstallBlock — code block with copy button.
 * Replaces 3 separate inline implementations.
 */
import CopyButton from './CopyButton.astro';

interface Props {
  command: string;
  class?: string;
}

const { command, class: className } = Astro.props;
---

<div data-slot="install-block" class:list={['install-block', className]}>
  <code class="install-block__cmd">{command}</code>
  <CopyButton text={command} />
</div>

<style>
  .install-block {
    display: flex;
    align-items: baseline;
    gap: 16px;
  }
  .install-block__cmd {
    font-family: var(--font-family-mono);
    font-size: clamp(13px, 1.4vw, 15px);
    color: var(--color-chalk);
    letter-spacing: 0.02em;
    user-select: all;
    white-space: nowrap;
    border-bottom: 1px solid var(--color-ash);
    padding-bottom: 4px;
  }
  @media (max-width: 480px) {
    .install-block {
      flex-direction: column;
      gap: 8px;
    }
    .install-block__cmd {
      font-size: 12px;
    }
  }
</style>
