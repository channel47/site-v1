---
/**
 * StatusBadge — maps tool status to Badge variant.
 * live → signal, dev → outline, soon → muted.
 */
import Badge from './Badge.astro';

interface Props {
  status: 'live' | 'dev' | 'soon';
}

const { status } = Astro.props;

const statusConfig: Record<string, { variant: 'signal' | 'outline' | 'muted'; label: string }> = {
  live: { variant: 'signal', label: 'Live' },
  dev: { variant: 'outline', label: 'In Dev' },
  soon: { variant: 'muted', label: 'Soon' },
};

const config = statusConfig[status];
---

<Badge variant={config.variant}>{config.label}</Badge>
