---
/**
 * EmailSignup — reusable email capture form.
 * Posts to /api/subscribe with tag and optional fields.
 * Three variants: inline (side-by-side), default, prominent.
 * Handles loading, success, and error states.
 */

interface Props {
  placeholder?: string;
  tag?: string;
  submitText?: string;
  class?: string;
  variant?: 'inline' | 'default' | 'prominent';
}

const {
  placeholder = 'your@email.com',
  tag = 'general',
  submitText = 'Join the Community',
  class: className = '',
  variant = 'default'
} = Astro.props;

const formId = `email-signup-${Math.random().toString(36).substr(2, 9)}`;
---

{variant === 'inline' ? (
  <form
    id={formId}
    class:list={['email-signup email-form', className]}
    data-signup-form
    data-tag={tag}
  >
    <label for={`${formId}-email`} class="sr-only">Email address</label>
    <input
      type="email"
      id={`${formId}-email`}
      name="email"
      placeholder={placeholder}
      required
      aria-required="true"
      class="email-form__input"
      autocomplete="email"
      spellcheck="false"
      data-original-placeholder={placeholder}
    />
    <button type="submit" class="email-form__btn email-signup__submit">
      <span class="email-signup__submit-text">{submitText}</span>
      <span class="email-signup__submit-icons relative w-4 h-4 shrink-0 inline-flex items-center" aria-hidden="true">
        <svg class="email-signup__icon email-signup__icon--arrow absolute inset-0 w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        <svg class="email-signup__icon email-signup__icon--check absolute inset-0 w-4 h-4 opacity-0 scale-[0.8]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 7"/></svg>
        <svg class="email-signup__icon email-signup__icon--loading absolute inset-0 w-4 h-4 opacity-0 scale-[0.8]" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" opacity="0.25"/><path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </span>
    </button>
    <p class="email-signup__status sr-only" aria-live="polite" data-signup-status></p>
  </form>
) : (
  <form
    id={formId}
    class:list={[
      'email-signup',
      variant === 'prominent' ? 'email-signup--prominent' : 'email-signup--default',
      className
    ]}
    data-signup-form
    data-tag={tag}
  >
    <label for={`${formId}-email`} class="sr-only">Email address</label>
    <input
      type="email"
      id={`${formId}-email`}
      name="email"
      placeholder={placeholder}
      required
      aria-required="true"
      class="email-signup__input"
      autocomplete="email"
      spellcheck="false"
      data-original-placeholder={placeholder}
    />
    <button type="submit" class="email-signup__submit">
      <span class="email-signup__submit-text">{submitText}</span>
      <span class="email-signup__submit-icons relative w-4 h-4 shrink-0" aria-hidden="true">
        <svg class="email-signup__icon email-signup__icon--arrow absolute inset-0 w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        <svg class="email-signup__icon email-signup__icon--check absolute inset-0 w-4 h-4 opacity-0 scale-[0.8]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 7"/></svg>
        <svg class="email-signup__icon email-signup__icon--loading absolute inset-0 w-4 h-4 opacity-0 scale-[0.8]" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" opacity="0.25"/><path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </span>
    </button>
    <p class="email-signup__status sr-only" aria-live="polite" data-signup-status></p>
  </form>
)}

<script>
  function initEmailSignup() {
    document.querySelectorAll<HTMLFormElement>('[data-signup-form]').forEach(form => {
      if (form.hasAttribute('data-initialized')) return;
      form.setAttribute('data-initialized', 'true');

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const input = form.querySelector<HTMLInputElement>('input[type="email"]');
        const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
        const status = form.querySelector<HTMLElement>('[data-signup-status]');
        const email = input?.value.trim();
        if (!email) return;

        const tag = form.dataset.tag || 'general';

        // Reset states
        form.classList.remove('is-success', 'is-error', 'is-server-error');
        form.classList.add('is-loading');
        if (btn) btn.disabled = true;
        if (input) input.removeAttribute('aria-invalid');
        if (status) status.textContent = 'Submitting...';

        try {
          const res = await fetch('/api/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, tag }),
          });

          const data = await res.json();
          form.classList.remove('is-loading');
          if (btn) btn.disabled = false;

          if (res.ok && data.success) {
            form.classList.add('is-success');
            if (input) {
              input.value = '';
              input.placeholder = 'You\'re in.';
            }
            if (status) status.textContent = 'Success! You\'re in.';
          } else {
            form.classList.add('is-error');
            if (input) input.setAttribute('aria-invalid', 'true');
            const msg = data.message || 'Something went wrong';
            if (input) input.placeholder = msg;
            if (status) status.textContent = msg;
          }
        } catch {
          form.classList.remove('is-loading');
          if (btn) btn.disabled = false;
          form.classList.add('is-server-error');
          if (input) input.setAttribute('aria-invalid', 'true');
          if (input) input.placeholder = 'Connection error. Try again.';
          if (status) status.textContent = 'Connection error. Try again.';
        }

        // Reset error states after delay
        setTimeout(() => {
          form.classList.remove('is-error', 'is-server-error');
          const input = form.querySelector<HTMLInputElement>('input[type="email"]');
          if (input && !form.classList.contains('is-success')) {
            input.placeholder = input.dataset.originalPlaceholder || 'your@email.com';
            input.removeAttribute('aria-invalid');
          }
        }, 3000);
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initEmailSignup);
  } else {
    initEmailSignup();
  }
  document.addEventListener('astro:page-load', initEmailSignup);
</script>

<style>
  .email-signup__icon {
    transition: opacity 100ms var(--ease-out), transform 100ms var(--ease-out);
  }
  .email-signup.is-loading .email-signup__submit-text { opacity: 0.6; }
  .email-signup.is-loading .email-signup__icon--arrow { opacity: 0; transform: scale(0.8); }
  .email-signup.is-loading .email-signup__icon--loading { opacity: 1; transform: scale(1); animation: spin 1s linear infinite; }
  .email-signup.is-success .email-signup__icon--arrow { opacity: 0; transform: scale(0.8); }
  .email-signup.is-success .email-signup__icon--check { opacity: 1; transform: scale(1); }
  .email-signup.is-success .email-signup__submit,
  .email-signup.is-success .email-form__btn { background: var(--color-success); }
  .email-signup.is-success .email-signup__input,
  .email-signup.is-success .email-form__input { border-color: var(--color-success); }
  .email-signup.is-error .email-signup__input,
  .email-signup.is-error .email-form__input { border-color: var(--color-destructive); animation: error-shake 0.3s var(--ease-out); }
  .email-signup.is-error .email-signup__input::placeholder,
  .email-signup.is-error .email-form__input::placeholder { color: var(--color-destructive); }
  .email-signup.is-server-error .email-signup__input,
  .email-signup.is-server-error .email-form__input { border-color: var(--color-destructive); }
  .email-signup.is-server-error .email-signup__input::placeholder,
  .email-signup.is-server-error .email-form__input::placeholder { color: var(--color-destructive); }
</style>
